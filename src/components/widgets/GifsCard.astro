---
import WidgetWrapper from "./WidgetWrapper.astro";

interface VideoCardItem {
  src: string;
  poster?: string;
  alt?: string;
}

interface Props {
  title?: string;
  description?: string;
  items?: VideoCardItem[];
  id?: string;
  isDark?: boolean;
  classes?: {
    container?: string;
    [key: string]: string | undefined;
  };
  bg?: string;
}

const {
  title = "",
  description = "",
  items = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
} = Astro.props as Props;

const { container: containerClassProp = "", ...otherClasses } = classes;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`mx-auto max-w-7xl ${containerClassProp}`}
  bg={bg}
  classes={otherClasses}
>
  {
    (title || description) && (
      <div class="mx-auto mb-12 max-w-4xl text-center">
        {title && (
          <h2 class="font-heading mb-8 bg-gradient-to-r from-red-500 via-green-500 to-blue-400 bg-[length:200%_200%] bg-clip-text pb-2 text-4xl font-extrabold leading-[1.15] tracking-tight text-transparent sm:text-5xl md:text-7xl md:pb-3 animate-gradient-x">
            {title}
          </h2>
        )}

        {description && (
          <p class="mx-auto max-w-3xl text-lg leading-8 text-muted-foreground md:text-xl">
            {description}
          </p>
        )}
      </div>
    )
  }

  <div class={`grid grid-cols-1 gap-8 ${
    items.length === 4 ? "md:grid-cols-2 lg:grid-cols-4" : "md:grid-cols-3"
  }`}>
    {
      items.map((item) => (
        <article class="overflow-hidden rounded-3xl border border-border bg-card shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="aspect-video w-full overflow-hidden bg-muted">
            <video
              class="h-full w-full object-cover"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster={item.poster || undefined}
              aria-label={item.alt || "Video preview"}
            >
              <source src={item.src} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </article>
      ))
    }
  </div>
</WidgetWrapper>