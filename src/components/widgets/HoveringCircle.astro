---
import WidgetWrapper from "./WidgetWrapper.astro";
import Headline from "@/components/ui/Headline.astro";
import { Icon } from "astro-icon/components";

interface HoveringCircleItem {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  items?: HoveringCircleItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  id?: string;
  isDark?: boolean;
  classes?: {
    container?: string;
    [key: string]: string | undefined;
  };
  bg?: string;
}

const {
  items = [],
  title = "",
  subtitle = "",
  tagline = "",
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
} = Astro.props as Props;

const { container: containerClassProp = "", ...otherClasses } = classes;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-7xl mx-auto ${containerClassProp}`}
  bg={bg}
  classes={otherClasses}
>
  {
    (title || subtitle || tagline) && (
      <Headline
        title={title}
        subtitle={subtitle}
        tagline={tagline}
        classes={{
          container: "max-w-3xl mx-auto text-center",
        }}
      />
    )
  }

  <div class="flex flex-col items-center justify-center gap-8 md:flex-row md:flex-wrap">
    {
      items.map((item) => (
        <article
          class="group relative flex h-96 w-full max-w-sm cursor-pointer items-center justify-center overflow-hidden rounded-3xl border border-border bg-card p-6 text-center shadow-sm transition-all duration-500 hover:bg-muted/50 hover:shadow-lg hover:shadow-primary/5 md:h-56 md:w-56 md:rounded-full md:hover:h-80 md:hover:w-96 md:hover:rounded-3xl"
        >
          <!-- Large background icon -->
          <div class="pointer-events-none absolute -right-5 -top-5 text-primary opacity-10 transition-all duration-500 group-hover:scale-110 group-hover:rotate-12">
            <Icon name={item.icon} class="h-32 w-32" />
          </div>

          <div class="relative z-10 flex flex-col items-center">
            <!-- Main icon -->
            <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary transition-all duration-500 group-hover:h-12 group-hover:w-12">
              <Icon name={item.icon} class="h-7 w-7" />
            </div>

            <h3 class="text-xl font-bold text-foreground transition-all duration-300">
              {item.title}
            </h3>

            <p class="mt-4 max-h-64 overflow-hidden text-sm leading-relaxed text-muted-foreground opacity-100 transition-all duration-500 md:mt-0 md:max-h-0 md:opacity-0 md:group-hover:mt-4 md:group-hover:max-h-48 md:group-hover:opacity-100">
              {item.description}
            </p>
          </div>
        </article>
      ))
    }
  </div>
</WidgetWrapper>