---
import WidgetWrapper from "./WidgetWrapper.astro";
import Card from "@/components/ui/Card.astro";
import Headline from "@/components/ui/Headline.astro";
import { Icon } from "astro-icon/components";

interface CareerListItem {
  title: string;
  description: string;
  icon: string;
  links?: {
    text: string;
    href: string;
  }[];
}

interface CareerListProps {
  services?: CareerListItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  id?: string;
  isDark?: boolean;
  classes?: {
    container?: string;
    [key: string]: string | undefined;
  };
  bg?: string;
}

const {
  services = [],
  title = "",
  subtitle = "",
  tagline = "",
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
} = Astro.props as CareerListProps;

const { container: containerClassProp = "", ...otherClasses } = classes;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={` ${containerClassProp}`}
  bg={bg}
  classes={otherClasses}
>
  <Headline
    title={title}
    subtitle={subtitle}
    tagline={tagline}
    classes={{
      container: "max-w-3xl mx-auto text-center",
    }}
  />
  <div class="flex flex-col items-center justify-center gap-20 md:flex-row md:flex-wrap">
    {
      services.map((s) => (
        <Card class="group relative w-full max-w-md overflow-hidden hover:bg-muted/50 hover:shadow-md">
          <div class="absolute -right-4 -top-4 text-8xl opacity-10 transition-transform group-hover:scale-110 group-hover:rotate-12 select-none">
            <Icon name={s.icon} class="w-32 h-32" />
          </div>
          <div class="text-left relative z-10">
            <div class="text-4xl mb-6 text-primary">
              <Icon name={s.icon} class="w-12 h-12" />
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-4">{s.title}</h3>
            <p class="text-muted-foreground leading-relaxed">{s.description}</p>
            {
              s.links && s.links.length > 0 && (
                <div class="mt-8 flex flex-wrap items-center gap-4">
                  {s.links.map((link) => (
                    <a
                      href={link.href}
                      class="flex items-center gap-2 font-semibold text-primary transition-all hover:underline group/btn"
                    >
                      {link.text}
                      <span class="transition-transform group-hover/btn:translate-x-1">
                        →
                      </span>
                    </a>
                  ))}
                </div>
              )
            }
          </div>
        </Card>
      ))
    }
  </div>
</WidgetWrapper>
