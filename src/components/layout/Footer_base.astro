---
import { siteConfig } from "@/config/site";

import { useTranslations } from "@/utils/i18n";

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <div class="flex items-center gap-3">
          <!-- Company Logo -->
          <img
            src="/black_logo.svg"
            alt="MBT Logo"
            class="h-8 w-auto dark:hidden"
          />
          <img
            src="/white_logo.svg"
            alt="MBT Logo"
            class="h-8 w-auto hidden dark:block"
          />
          <div class="flex flex-col">
            <!-- Company Name -->
            <span class="text-lg font-bold text-foreground">{siteConfig.name}</span>
            <!-- Company Moto -->
            <p class="text-sm text-muted-foreground">
              <!-- {siteConfig.description} -->
               {t("hero_subtitle")}
            </p>
          </div>
        </div>
      </div>
      <div class="flex flex-col items-center">
        <!-- {Company Email} -->
        <p class="text-sm text-muted-foreground">{t("contact")}: info@mbt-systems.de</p>        
        <!-- {Company Address} -->
        <span class="text-sm text-muted-foreground">Dieselstraße 11, 85757 Karlsfeld</span>
      </div>
      <div class="flex items-center gap-6">
        <a
          href={siteConfig.socialLinks.twitter}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >Twitter
        </a>
        <a
          href={siteConfig.socialLinks.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >GitHub
        </a>
        <a
        href={siteConfig.socialLinks.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground transition-colors hover:text-primary"
        >LinkedIn
        </a>
        <a
          href={siteConfig.socialLinks.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-primary"
          >Facebook
        </a>
      </div>
    </div>
    <!-- <div
    class="mt-4 border-t border-border pt-8 text-center text-xs text-muted-foreground"
    > -->
    <div class="mt-4 border-t border-border pt-8 text-xs text-muted-foreground">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
         <!-- Legal Links -->
        <div class="flex flex-col items-start gap-2 md:flex-row md:items-center md:gap-6">
          <a href={`/${lang}/legal`} class="hover:text-primary transition-colors">
            {t("footer_LN")}
          </a>
          <a href={`/${lang}/gtc`} class="hover:text-primary transition-colors">
            {t("footer_GTC")}
          </a>
          <a href={`/${lang}/privacy`} class="hover:text-primary transition-colors">
            {t("footer_P")}
          </a>
        </div>
        <!-- <div class="text-left md:text">
          Dieselstraße 11, 85757 Karlsfeld
        </div> -->
        <div class="text-left md:text-right">
          Copyright &copy; {new Date().getFullYear()}
          {siteConfig.author}. {t("footer_ARS")}
        </div>
      </div>
    </div>
  </div>
</footer>
